# ─── Node / Wrangler ─────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/

# Wrangler local state and secrets
.wrangler/
.dev.vars
.dev.vars.*
worker/.wrangler/
worker/.dev.vars
worker/dist/
worker/build/

# ─── Python / FastAPI ────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.Python
.venv/
venv/
env/
.pytest_cache/

# ─── Cloudflare Tunnel credentials ───────────────────────────────
# Never commit tunnel credentials (they grant access to your tunnel)
*.pem
cert.pem
tunnel/*.json
**/.cloudflared/*.json

# ─── Environment / Secrets ───────────────────────────────────────
.env
.env.*
!.env.example
*.key
secrets.json
secrets.yaml

# ─── OS / Editor ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ─── Logs ────────────────────────────────────────────────────────
*.log
logs/

# ─── Accidental folder from PowerShell brace-expansion mishap ────
{worker,backend,docs}/
